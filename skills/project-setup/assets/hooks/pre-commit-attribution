# BEGIN agent-guidelines staged attribution guard
# Catches three shapes of AI-tool authorship in staged content:
#   - Footer/trailer (specific colon-suffixed trailer keys)
#   - Prepositional (a contribution verb followed by by/with/using
#     and an AI subject)
#   - Adjective (an AI subject prefixing a contribution verb as a
#     hyphenated modifier)
# The trailer keys are assembled from adjacent quoted fragments so the
# guard's own definition does not match the pattern when this snippet
# is itself staged. Plain POSIX sh: no arrays, no process substitution.
attribution_pattern='((co-)?authored''-by:|generated''-by:|written''-by:|reviewed''-by:|planned''-by:|developed''-by:|(generated|written|reviewed|planned|implemented|authored|co-authored|developed) (by|with|using) .*(ai|llm|assistant|agent|bot|automation|code assistant|coding agent|coding tool)|(ai|llm)-(generated|written|authored|reviewed|planned|implemented|coded|assisted|developed))'

if git diff --cached --diff-filter=ACMR | grep -Ei "^\+.*${attribution_pattern}" >/dev/null; then
  echo "Development-tool attribution found in staged content:" >&2
  git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r staged_file; do
    if [ -f "$staged_file" ] &&
      git diff --cached -- "$staged_file" | grep -Ei "^\+.*${attribution_pattern}" >/dev/null; then
      echo "  $staged_file" >&2
    fi
  done
  exit 1
fi
# END agent-guidelines staged attribution guard
