# BEGIN agent-guidelines conventional commit guard
commit_msg_file="$1"
subject="$(sed -n '1p' "$commit_msg_file")"

if ! printf '%s\n' "$subject" | grep -E '^(feat|fix|refactor|perf|docs|style|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?(!)?: [a-z0-9].+$' >/dev/null; then
  echo "Commit subject must use Conventional Commits:" >&2
  echo "  <type>(<scope>): <description>" >&2
  echo "Allowed types: feat, fix, refactor, perf, docs, style, test, build, ci, chore, revert" >&2
  exit 1
fi

if [ "${#subject}" -gt 60 ]; then
  echo "Commit subject is ${#subject} characters; hard limit is 60." >&2
  echo "Target is 50 characters; a few characters over is acceptable when it improves clarity." >&2
  exit 1
fi
# END agent-guidelines conventional commit guard
