# BEGIN agent-guidelines branch-name guard
# Validates the branches actually being pushed, read from the ref list
# git supplies on stdin, rather than the currently checked-out branch.
# Deletions are allowed so a badly named remote branch can still be
# removed; tag and non-branch refs are not name-checked. Beyond the
# type-prefix pattern, names are rejected when they carry the
# no-plans-on-main forward-looking phrasing, since a branch name lands
# on the default branch as the merge commit's subject. The pattern is
# assembled from adjacent quoted fragments so this snippet does not
# match the staged guard when it is itself committed.
branch_banned_pattern='(will be'' added|will'' land|will'' follow|coming'' soon|next'' session|future'' work|road''map|follow''-?ups?|next''-steps?|to''-do|up''coming|not'' yet|first'' (caller|migration|concrete)|(TO''DO|FIX''ME):)'

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$local_sha" in
    *[!0]*) ;;
    *) continue ;;
  esac

  case "$remote_ref" in
    refs/heads/*) pushed_branch="${remote_ref#refs/heads/}" ;;
    *) continue ;;
  esac

  case "$pushed_branch" in
    main|feat/*|fix/*|chore/*|docs/*|refactor/*|test/*|build/*|ci/*|perf/*|style/*|revert/*)
      ;;
    *)
      echo "Refusing to push '$pushed_branch': branch names must use main or a Conventional Commit type prefix." >&2
      echo "Examples: feat/setup-skill, fix/hook-install" >&2
      exit 1
      ;;
  esac

  if printf '%s\n' "$pushed_branch" | grep -Ei "$branch_banned_pattern" >/dev/null; then
    echo "Refusing to push '$pushed_branch': branch names must not carry forward-looking (planned-work) phrasing." >&2
    echo "Rename the branch to describe the present (see the no-plans-on-main rule)." >&2
    exit 1
  fi
done
# END agent-guidelines branch-name guard
