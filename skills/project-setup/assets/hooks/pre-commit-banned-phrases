# BEGIN agent-guidelines staged banned-phrase guard
# Rejects forward-looking, planned-work phrasing in staged content so
# permanent history reads as a record of work that happened. The
# phrase list comes from the no-plans-on-main rule; that rule file is
# exempt wherever it is installed because it defines the list. The
# pattern is assembled from adjacent quoted fragments so the guard's
# own definition does not match the pattern when this snippet is
# itself staged. Plain POSIX sh: no arrays, no process substitution.
banned_pattern='(will be'' added|will'' land|will'' follow|coming'' soon|next'' session|future'' work|road''map|follow''-?ups?|next''-steps?|to''-do|up''coming|not'' yet|first'' (caller|migration|concrete)|(TO''DO|FIX''ME):)'

banned_hits="$(git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r staged_file; do
  case "$staged_file" in
    no-plans-on-main.md|*/no-plans-on-main.md) continue ;;
  esac
  if git diff --cached -- "$staged_file" | grep -Ei "^\+.*${banned_pattern}" >/dev/null; then
    printf '  %s\n' "$staged_file"
  fi
done)"

if [ -n "$banned_hits" ]; then
  echo "Forward-looking (planned-work) phrasing found in staged content:" >&2
  printf '%s\n' "$banned_hits" >&2
  echo "Rewrite to describe the present; plans belong outside permanent history (see the no-plans-on-main rule)." >&2
  exit 1
fi
# END agent-guidelines staged banned-phrase guard
